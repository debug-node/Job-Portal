# Database Configuration
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=jobportal

# Redis Configuration
REDIS_PASSWORD=redis123
REDIS_URL=redis://:redis123@redis:6379

# JWT Secret
JWT_SEC=your-super-secret-jwt-key-change-in-production

# Kafka Configuration
KAFKA_BROKER=kafka:9092

# API URLs
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000
UPLOAD_SERVICE=http://localhost:5000

# Razorpay (Payment Gateway)
RAZORPAY_KEY=rzp_test_your_test_key_here
RAZORPAY_SECRET=your_razorpay_secret_here
NEXT_PUBLIC_RAZORPAY_KEY=rzp_test_your_test_key_here

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Gmail SMTP (Email Service)
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password

# Google Gemini AI (Resume Analysis)
GEMINI_API_KEY=your_gemini_api_key
